# Copy to .env and adjust. NEVER commit the real .env.

# PostgreSQL
POSTGRES_DB=freeswitch_control
POSTGRES_USER=freeswitch
POSTGRES_PASSWORD=freeswitch

# Control Plane API token (used by Terraform provider).
API_TOKEN=dev-token

# Remote FreeSWITCH ESL (mod_event_socket) on the FS server.
ESL_ADDR=192.168.48.143:8021
# Must match the password in the FS server's event_socket.conf.xml. CHANGE it.
ESL_PASSWORD=change-me-esl-secret

# Protect the FreeSWITCH-facing /xml/* endpoints (they expose SIP passwords and
# trunk secrets). mod_xml_curl authenticates with these via gateway-credentials
# (see deploy/freeswitch/xml_curl.conf.xml). CHANGE the password.
XML_USER=freeswitch
XML_PASSWORD=change-me-xml-secret
# Optional defense-in-depth IP allowlist (comma-separated CIDRs). Empty = off.
# NOTE: behind Docker/NAT the observed source IP may differ; verify before relying on it.
XML_ALLOW_CIDRS=

# TLS. Generate certs with hack/gen-tls.sh (writes deploy/tls/, mounted at /tls).
# If TLS_CERT_FILE+TLS_KEY_FILE are set the control-plane serves HTTPS.
# If XML_CLIENT_CA_FILE is set, /xml/* also requires a client cert (mTLS).
# Leave all three blank to fall back to plain HTTP.
TLS_CERT_FILE=/tls/server.crt
TLS_KEY_FILE=/tls/server.key
XML_CLIENT_CA_FILE=/tls/ca.crt
# Recordings file server (nginx on the FS host) for /api/v1/recordings
REC_URL=http://192.168.48.143:8088
REC_USER=recordings
REC_PASSWORD=change-me
# Grafana NOC dashboard (http://localhost:3000)
GRAFANA_DB_PASSWORD=change-me-ro
GRAFANA_ADMIN_PASSWORD=change-me-admin
# Phone provisioning (GET /provision/<mac>); configs carry the SIP password
PROVISION_USER=provision
PROVISION_PASSWORD=change-me
PROVISION_SIP_SERVER=192.168.48.143
